{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@card-games/deck": ["./packages/deck/src/index.ts"],
      "@card-games/standard-cards": ["./packages/standard-cards/src/index.ts"],
      "@card-games/scoundrel": ["./packages/scoundrel/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "vitest.config.ts"]
}
